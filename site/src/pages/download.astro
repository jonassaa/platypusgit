---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
import CodeBlock from '../components/CodeBlock.astro';
import OsIcon from '../components/OsIcon.astro';
import { site, assets } from '../data/site.ts';

const buildSteps = `# Prerequisites: Node 22+, pnpm, Rust stable
#   macOS:   xcode-select --install
#   Linux:   libwebkit2gtk-4.1-dev build-essential libssl-dev
#   Windows: WebView2 + MSVC Build Tools

git clone ${site.repo}.git
cd platypusgit
pnpm install
pnpm tauri build   # produces .dmg / .msi / .deb / .AppImage`;
---
<Layout title={'Download — ' + site.name}>
  <section class="container page-head">
    <h1>Download</h1>
    <p class="lead">platypusgit runs on macOS, Windows, and Linux. Pick your platform below. Prebuilt binaries live on GitHub Releases.</p>
    <div class="head-ctas">
      <CTAButton href={site.releasesLatest} external>Latest release</CTAButton>
      <CTAButton href={site.releases} variant="secondary" external>All releases</CTAButton>
    </div>
    <div class="os-tabs" data-os-tabs>
      <button class="os-tab" data-os="macos" type="button"><OsIcon os="macos" size={15} /> macOS</button>
      <button class="os-tab" data-os="windows" type="button"><OsIcon os="windows" size={15} /> Windows</button>
      <button class="os-tab" data-os="linux" type="button"><OsIcon os="linux" size={15} /> Linux</button>
    </div>
  </section>

  <section class="container">
    <div class="notice">
      <strong>Builds are early pre-releases.</strong> Every published release attaches prebuilt
      binaries for all three platforms — macOS <code>.dmg</code>, Windows <code>.msi</code>,
      Linux <code>.deb</code> &amp; <code>.AppImage</code>. Grab the newest from the
      <a href={site.releases} target="_blank" rel="noopener">Releases page</a>, or
      <a href="#build">build from source</a>.
    </div>
  </section>

  <!-- INSTALL: macOS -->
  <section class="container install" id="macos" data-os-section="macos">
    <div class="install-head">
      <h2><OsIcon os="macos" size={22} /> macOS</h2>
      <p>Apple Silicon &amp; Intel.</p>
    </div>

    <div class="method">
      <h3>Homebrew</h3>
      <CodeBlock code={'brew install --cask jonassaa/platypusgit/platypusgit'} lang="bash" />
      <p class="method-note">The app is ad-hoc signed but not notarized. The cask clears the macOS Gatekeeper quarantine flag on install, so it launches with no "unidentified developer" prompt.</p>
    </div>

    <div class="method">
      <h3>DMG</h3>
      <p class="method-note">Download the universal <code>.dmg</code> and drag <code>platypusgit.app</code> into <code>/Applications</code>.</p>
      <CTAButton href={assets.macosDmg} external>Download .dmg</CTAButton>
    </div>

    <div class="method">
      <h3>First launch — DMG, unsigned build</h3>
      <p class="method-note">DMG installs aren't notarized, so on first launch macOS may say the app is damaged or from an unidentified developer. Clear the quarantine flag (the Homebrew cask already handles this):</p>
      <CodeBlock code={'xattr -cr /Applications/platypusgit.app'} lang="bash" />
      <p class="method-note">Or: <strong>System Settings → Privacy &amp; Security → Open Anyway</strong> for platypusgit.</p>
    </div>
  </section>

  <!-- INSTALL: Windows -->
  <section class="container install" id="windows" data-os-section="windows">
    <div class="install-head">
      <h2><OsIcon os="windows" size={20} /> Windows</h2>
      <p>Windows 10 &amp; 11. WebView2 ships with Windows 11.</p>
    </div>

    <div class="method">
      <h3>Installer (.msi)</h3>
      <p class="method-note">Download the 64-bit <code>.msi</code> and run it.</p>
      <CTAButton href={assets.windowsMsi} external>Download .msi</CTAButton>
    </div>

    <div class="method">
      <h3>First launch — unsigned build</h3>
      <p class="method-note">The installer isn't code-signed yet, so Windows SmartScreen shows a warning. Click <strong>More info → Run anyway</strong> to proceed.</p>
    </div>
  </section>

  <!-- INSTALL: Linux -->
  <section class="container install" id="linux" data-os-section="linux">
    <div class="install-head">
      <h2><OsIcon os="linux" size={22} /> Linux</h2>
      <p>Needs <code>webkit2gtk 4.1</code>. Two formats — Debian package or portable AppImage.</p>
    </div>

    <div class="method">
      <h3>Debian / Ubuntu (.deb)</h3>
      <p class="method-note">Download the package, then install it:</p>
      <CodeBlock code={'sudo apt install ./PlatypusGit_amd64.deb'} lang="bash" />
      <CTAButton href={assets.linuxDeb} external>Download .deb</CTAButton>
    </div>

    <div class="method">
      <h3>AppImage (portable)</h3>
      <p class="method-note">Download, make it executable, and run — no install needed:</p>
      <CodeBlock code={'chmod +x PlatypusGit_amd64.AppImage\n./PlatypusGit_amd64.AppImage'} lang="bash" />
      <CTAButton href={assets.linuxAppImage} external>Download .AppImage</CTAButton>
    </div>
  </section>

  <!-- BUILD FROM SOURCE -->
  <section class="container build" id="build">
    <h2>Build from source</h2>
    <p class="lead">Standard Tauri toolchain. Works on all three platforms.</p>
    <CodeBlock code={buildSteps} lang="bash" />
    <p class="readme-link"><a href={site.repo + '#development'} target="_blank" rel="noopener">Full development guide on GitHub →</a></p>
  </section>
</Layout>

<script>
  // OS selector: sniff platform (or honor #hash), show that install section.
  (function () {
    var sections = Array.from(document.querySelectorAll('[data-os-section]'));
    var tabs = Array.from(document.querySelectorAll('.os-tab'));
    if (!sections.length || !tabs.length) return;
    var known = ['macos', 'windows', 'linux'];

    function detect() {
      var hash = (location.hash || '').replace('#', '');
      if (known.indexOf(hash) !== -1) return hash;
      return 'macos';
    }

    function select(os) {
      sections.forEach(function (s) { s.hidden = s.getAttribute('data-os-section') !== os; });
      tabs.forEach(function (t) { t.classList.toggle('on', t.getAttribute('data-os') === os); });
    }

    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        var os = t.getAttribute('data-os');
        select(os);
        history.replaceState(null, '', '#' + os);
      });
    });

    select(detect());
    window.addEventListener('hashchange', function () {
      var hash = (location.hash || '').replace('#', '');
      if (known.indexOf(hash) !== -1) select(hash);
    });
  })();
</script>

<style>
  .page-head { padding-top: var(--s-12); }
  .os-tabs { display: inline-flex; margin-top: var(--s-8); border: 1px solid var(--border-1);
    border-radius: var(--r-5); overflow: hidden; }
  .os-tab { display: inline-flex; align-items: center; gap: 7px; padding: 8px 18px; background: transparent;
    border: none; border-right: 1px solid var(--border-1);
    color: var(--fg-2); font-family: var(--font-sans); font-size: 14px; font-weight: 600; cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast); }
  .os-tab:last-child { border-right: none; }
  .os-tab:hover { color: var(--fg-0); }
  .os-tab.on { background: var(--accent); color: var(--accent-ink); }
  [data-os-section][hidden] { display: none; }
  .page-head h1 { font-size: 38px; margin: 0 0 var(--s-4); }
  .lead { color: var(--fg-2); font-size: 16px; max-width: 640px; margin: 0; }
  .head-ctas { display: flex; gap: var(--s-4); margin-top: var(--s-7); flex-wrap: wrap; }
  .notice { background: color-mix(in oklab, var(--accent-2) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent-2) 40%, transparent);
    color: var(--fg-1); padding: var(--s-5) var(--s-6); border-radius: var(--r-5);
    margin: var(--s-10) 0 0; font-size: 14px; }
  .notice a { color: var(--accent); }

  .install { margin-top: var(--s-11); padding-bottom: var(--s-9); border-bottom: 1px solid var(--border-0); scroll-margin-top: 72px; }
  .install-head { margin-bottom: var(--s-7); }
  .install-head h2 { font-size: 26px; margin: 0 0 var(--s-2); display: flex; align-items: center; gap: var(--s-4); }
  .install-head p { color: var(--fg-3); font-size: 14px; margin: 0; }
  .os-glyph { width: 8px; height: 8px; border-radius: 999px; background: var(--accent); display: inline-block; }

  .method { margin-top: var(--s-7); max-width: 760px; }
  .method h3 { font-size: 15px; margin: 0 0 var(--s-4); color: var(--fg-0); font-family: var(--font-sans); font-weight: 600; }
  .method-note { color: var(--fg-2); font-size: 14px; margin: 0 0 var(--s-4); line-height: 1.6; }
  .method-note code { background: var(--bg-2); border: 1px solid var(--border-0); border-radius: var(--r-2);
    padding: 1px 5px; font-size: 12px; color: var(--fg-1); }
  .method-note a { color: var(--accent); }

  .build { margin-top: var(--s-12); scroll-margin-top: 72px; }
  .build h2 { font-size: 26px; margin: 0 0 var(--s-3); }
  .build .lead { margin-bottom: var(--s-7); }
  .readme-link { margin-top: var(--s-6); font-size: 14px; }
</style>
