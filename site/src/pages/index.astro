---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
import FeatureCard from '../components/FeatureCard.astro';
import AppShowcase from '../components/AppShowcase.astro';
import OsIcon from '../components/OsIcon.astro';
import { site, downloads } from '../data/site.ts';
import { heroFeatures } from '../data/features.ts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const availableDownloads = downloads.filter((d) => d.available);
const comingSoon = downloads.filter((d) => !d.available);
---
<Layout title={site.name + ' — ' + site.tagline}>
  <!-- HERO — statement first -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="brand-lockup">
        <img class="brand-logo" src={base + '/logo.svg'} alt="" width="92" height="92" />
        <span class="brand-word mono">platypusgit</span>
      </div>
      <h1 class="hero-title">Free, open source git.<br />Built for developers.</h1>
      <span class="badge mono">open source git client · GPLv3</span>
      <p class="hero-sub">
        A native desktop git client for macOS, Windows, and Linux — no account, no paywall,
        unlike every other cross-platform GUI worth using.
      </p>

      <!-- primary download + coming-soon line -->
      <div class="os-picker">
        {availableDownloads.map((d) => (
          <a class="os-btn primary" href={base + d.anchor} data-os={d.key}>
            <OsIcon os={d.key} size={24} />
            <span class="os-text">
              <span class="os-name">Download for {d.label}</span>
              <span class="os-note">{d.note}</span>
            </span>
          </a>
        ))}
      </div>
      {comingSoon.length > 0 && (
        <p class="os-soon">
          <span class="os-soon-label">Coming soon:</span>
          {comingSoon.map((d) => (
            <span class="os-soon-os"><OsIcon os={d.key} size={13} /> {d.label}</span>
          ))}
        </p>
      )}
      <div class="hero-ctas">
        <CTAButton href={base + '/download'} variant="secondary">All download options →</CTAButton>
        <CTAButton href={site.repo} variant="secondary" external>View on GitHub ↗</CTAButton>
      </div>

      <ul class="hero-trust mono">
        <li>No account</li>
        <li>No paywall</li>
        <li>No feature tiers</li>
        <li>No telemetry</li>
      </ul>
      <a class="stars" href={site.repo} target="_blank" rel="noopener">
        <img src="https://img.shields.io/github/stars/jonassaa/platypusgit?style=flat&label=star&color=3E9B91" alt="GitHub stars" height="20" />
      </a>
    </div>
  </section>

  <!-- SHOWCASE — the real UI -->
  <section class="container showcase">
    <div class="showcase-head">
      <h2 class="section-title">The whole repo, at a glance.</h2>
      <p class="showcase-sub">Real commit-graph rendering — branches, merges, tags, and refs. This is the actual history view, running right here.</p>
    </div>
    <AppShowcase />
  </section>

  <!-- IN DEVELOPMENT notice -->
  <div class="container">
    <div class="dev-notice">
      <span class="dev-tag mono">In development</span>
      <p>
        platypusgit is under active development — expect frequent releases and rough edges.
        Got a feature idea or hit a bug? <a href={site.repo + '/issues'} target="_blank" rel="noopener">Propose it on GitHub Issues ↗</a>
      </p>
    </div>
  </div>

  <!-- WHY — strengths vs other clients -->
  <section class="why">
    <div class="container why-grid">
      <div class="why-item"><h3>Free for everyone</h3><p>No license fees, no per-seat pricing, no "pro" tier. Every feature, every platform, zero cost — for solo devs, teams, and companies alike.</p></div>
      <div class="why-item"><h3>Open source</h3><p>GPLv3. Read the code, file issues, send patches. No telemetry, no account, no lock-in. Your repos and history never leave your machine.</p></div>
      <div class="why-item"><h3>Dev-first</h3><p>A TortoiseGit alternative designed around how developers actually work — keyboard-driven, dense, no hand-holding. Hunks, rebases, conflicts — all first-class.</p></div>
      <div class="why-item"><h3>Cross-platform & native</h3><p>Small native binary with real windows on macOS, Windows, and Linux — not a bundled browser.</p></div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="container section">
    <h2 class="section-title">Everything you do with git. In one window.</h2>
    <div class="feature-grid">
      {heroFeatures.map((f) => <FeatureCard title={f.title} blurb={f.blurb} />)}
    </div>
    <div class="section-cta">
      <CTAButton href={base + '/features'} variant="secondary">See the full feature list →</CTAButton>
    </div>
  </section>
</Layout>

<style>
  .hero { padding: var(--s-13) 0 var(--s-12); border-bottom: 1px solid var(--border-0);
    background: radial-gradient(1200px 460px at 50% -20%, color-mix(in oklab, var(--accent) 14%, transparent), transparent); }
  .hero-inner { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .brand-lockup { display: inline-flex; align-items: center; gap: var(--s-5); margin-bottom: var(--s-7); }
  .brand-logo { display: block; filter: drop-shadow(0 4px 16px color-mix(in oklab, var(--accent) 35%, transparent)); }
  .brand-word { font-size: 56px; font-weight: 700; letter-spacing: -0.015em; color: var(--fg-0); }
  .badge { display: inline-block; font-size: 12px; color: var(--accent); border: 1px solid var(--border-1);
    padding: 4px 10px; border-radius: 999px; margin-bottom: var(--s-6); }
  .hero-title { font-size: 34px; margin: 0 0 var(--s-5); line-height: 1.15; font-weight: 700; }
  .hero-sub { color: var(--fg-2); font-size: 17px; max-width: 620px; margin: 0 0 var(--s-8); line-height: 1.6; }

  .os-picker { display: flex; gap: var(--s-4); flex-wrap: wrap; justify-content: center; margin-bottom: var(--s-4); }
  .os-btn { display: flex; flex-direction: row; align-items: center; gap: 12px; position: relative;
    padding: 12px 22px; border-radius: var(--r-5); border: 1px solid var(--border-2); background: var(--bg-1);
    color: var(--fg-0); transition: transform var(--t-fast), border-color var(--t-fast), background var(--t-fast); }
  .os-btn:hover { text-decoration: none; transform: translateY(-1px); border-color: var(--accent); }
  .os-btn .os-text { display: flex; flex-direction: column; align-items: flex-start; gap: 2px; }
  .os-btn .os-name { font-weight: 600; font-size: 15px; }
  .os-btn .os-note { font-size: 12px; color: var(--fg-3); }
  .os-btn.primary { background: var(--accent); border-color: var(--accent); color: var(--accent-ink);
    box-shadow: 0 6px 20px color-mix(in oklab, var(--accent) 30%, transparent); }
  .os-btn.primary:hover { border-color: var(--accent); }
  .os-btn.primary .os-note { color: color-mix(in oklab, var(--accent-ink) 75%, transparent); }

  .os-soon { display: inline-flex; align-items: center; gap: var(--s-4); flex-wrap: wrap; justify-content: center;
    margin: 0 0 var(--s-6); font-size: 13px; color: var(--fg-3); }
  .os-soon-label { text-transform: uppercase; letter-spacing: 0.05em; font-size: 11px; color: var(--fg-4); }
  .os-soon-os { display: inline-flex; align-items: center; gap: 5px; }

  .hero-ctas { display: flex; gap: var(--s-4); margin-bottom: var(--s-7); flex-wrap: wrap; justify-content: center; }
  .hero-ctas :global(.cta) { padding: 7px 13px; font-size: 13px; }
  .hero-trust { display: flex; gap: var(--s-6); flex-wrap: wrap; justify-content: center; list-style: none;
    padding: 0; margin: 0 0 var(--s-7); }
  .hero-trust li { display: inline-flex; align-items: center; gap: 6px; color: var(--fg-2); font-size: 13px; }
  .hero-trust li::before { content: '✓'; color: var(--accent); font-weight: 700; }
  .stars { display: inline-block; }

  .dev-notice { display: flex; align-items: center; gap: var(--s-5); margin: var(--s-11) 0 0;
    padding: var(--s-5) var(--s-6); border-radius: var(--r-5);
    background: color-mix(in oklab, var(--accent-2) 10%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent-2) 38%, transparent); }
  .dev-tag { flex-shrink: 0; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--accent-2); border: 1px solid color-mix(in oklab, var(--accent-2) 50%, transparent);
    padding: 3px 9px; border-radius: 999px; }
  .dev-notice p { margin: 0; color: var(--fg-1); font-size: 14px; line-height: 1.5; }
  .dev-notice a { color: var(--accent); font-weight: 600; }

  .section { padding-top: var(--s-12); }
  .section-title { font-size: 26px; text-align: center; margin: 0 0 var(--s-10); }
  .showcase { padding-top: var(--s-12); }
  .showcase-head { text-align: center; margin-bottom: var(--s-9); }
  .showcase-head .section-title { margin-bottom: var(--s-4); }
  .showcase-sub { color: var(--fg-2); font-size: 16px; max-width: 560px; margin: 0 auto; }
  .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6); }
  .section-cta { text-align: center; margin-top: var(--s-9); }
  .why { background: var(--bg-1); border-top: 1px solid var(--border-0); border-bottom: 1px solid var(--border-0);
    margin-top: var(--s-13); padding: var(--s-12) 0; }
  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-9); }
  .why-item h3 { font-size: 18px; margin: 0 0 var(--s-3); color: var(--accent); }
  .why-item p { color: var(--fg-2); margin: 0; font-size: 15px; }
  @media (max-width: 820px) {
    .brand-word { font-size: 38px; }
    .brand-logo { width: 64px; height: 64px; }
    .hero-title { font-size: 24px; }
    .feature-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .os-picker { flex-direction: column; align-items: stretch; width: 100%; max-width: 320px; }
    .os-btn { align-items: center; text-align: center; }
  }
</style>
